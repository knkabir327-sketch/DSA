#include<iostream>
using namespace std;
int main(){
    int n;
    cout<<"Enter size of array: ";
    cin>>n;
    int arr[n];
    int ans[n];

    for(int i=0; i<; i++){
        cin>>arr[i];
    }
    for(int i=0; i<n; i++){
        ans[i]=-1;
        for(int j=i-1; j>=0; j--){
            if(arr[j]<arr[i]){
                ans[i]= arr[j];
                break;
            }
        }
    }
    cout<<"Previous smaller elements: ";
    for(int i=0; i<n; i++){
        cout<<ans[i]<<" ";
    }
    return 0;
}
